# Required: OpenAI-compatible API credential used by the backend.
AI_API_KEY=

# Optional: override if you use a compatible provider or self-hosted gateway.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Optional: point to a custom FFmpeg binary.
FFMPEG_PATH=ffmpeg

# Optional: host port for the web UI (default 3000). Do not set to 8080 (backend internal port).
# FRONTEND_PORT=3000
